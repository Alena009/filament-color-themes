{
    "name": "alenadashko/filament-color-themes",
    "description": "Color themes switcher plugin for Filament panels",
    "keywords": [
        "filament",
        "filamentphp",
        "laravel",
        "themes",
        "colors"
    ],
    "homepage": "https://github.com/Alena009/filament-color-themes",
    "license": "MIT",
    "authors": [
        {
            "name": "Alena009",
            "email": "dashkoalena@gmail.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "filament/filament": "^3.2|^5.0",
        "spatie/laravel-package-tools": "^1.15.0"
    },
    "autoload": {
        "psr-4": {
            "AlenaDashko\\FilamentColorThemes\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "AlenaDashko\\FilamentColorThemes\\ColorThemesServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "sort-packages": true
    }
}
