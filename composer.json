{
    "name": "dashk/filament-color-themes",
    "description": "Color themes switcher plugin for Filament panels",
    "keywords": [
        "filament",
        "filamentphp",
        "laravel",
        "themes",
        "colors"
    ],
    "homepage": "https://github.com/dashk/filament-color-themes",
    "license": "MIT",
    "authors": [
        {
            "name": "Dashk",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "filament/filament": "^5.0",
        "spatie/laravel-package-tools": "^1.15.0"
    },
    "autoload": {
        "psr-4": {
            "Dashk\\FilamentColorThemes\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Dashk\\FilamentColorThemes\\ColorThemesServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "sort-packages": true
    }
}
